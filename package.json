{
  "name": "novarum",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --parallel --filter '*' dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "anchor:docker": "docker build -f apps/anchor/Dockerfile -t ghcr.io/novarumsocial/anchor:latest .",
    "anchor:push": "docker push ghcr.io/novarumsocial/anchor:latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "apps/*"
  ]
}
