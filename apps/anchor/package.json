{
  "name": "anchor",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "contract:emit": "bun prisma-next contract emit",
    "db:init": "bun prisma-next db init",
    "db:update": "bun prisma-next db update",
    "db:verify": "bun prisma-next db verify",
    "migration:plan": "bun prisma-next migration plan",
    "migrate": "bun prisma-next migrate",
    "migration:status": "bun prisma-next migration status",
    "migration:show": "bun prisma-next migration show",
    "build": "bun build --compile --target bun --outfile ../../testing/server src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@prisma-next/postgres": "latest",
    "aws4fetch": "^1.0.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "elysia": "latest",
    "livekit-server-sdk": "^2.15.5",
    "toml": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma-next/adapter-postgres": "latest",
    "@prisma-next/cli": "latest",
    "@prisma-next/contract": "latest",
    "@prisma-next/sql-contract": "latest",
    "@prisma-next/sql-orm-client": "latest",
    "@prisma-next/target-postgres": "latest",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.2",
    "bun-types": "latest",
    "drizzle-kit": "^1.0.0-rc.4",
    "prisma-next": "latest"
  },
  "module": "src/index.js"
}
