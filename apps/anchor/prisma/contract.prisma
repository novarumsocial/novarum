model User {
  id             String @id
  username       String
  homeserver     String @map("homeserverName")
  displayName    String?
  avatarUrl      String?
  isBot          Boolean
  createdAt      DateTime
  updatedAt      DateTime
  status         String @default("OFFLINE")

  @@unique([username, homeserver])
  @@map("user")
  sessions         Session[]
  memberships GuildMember[]
  ownedGuilds Guild[]      @relation("GuildOwner")
  messages         Message[]
  invites          GuildInvite[] @relation("GuildInviteCreator")
}

model LocalCredential {
  userId       String @id
  email        String @unique
  passwordHash String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("local_credential")
}

model Session {
  id         String   @id
  userId     String
  secretHash Bytes
  createdAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Guild {
  id          String   @id
  name        String
  description String?
  avatarUrl   String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   temporal.updatedAt()

  owner    User          @relation("GuildOwner", fields: [ownerId], references: [id])
  members  GuildMember[]
  channels Channel[]
  invites  GuildInvite[]

  @@index([ownerId])
  @@map("guild")
}

model GuildMember {
  guildId  String
  userId   String
  role     String    @default("MEMBER")
  joinedAt DateTime  @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([userId])
  @@map("guild_member")
}

model Channel {
  id          String      @id
  guildId     String
  name        String
  type        String      @default("TEXT")
  position    Int
  createdAt   DateTime    @default(now())
  updatedAt   temporal.updatedAt()

  guild    Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([guildId, name])
  @@index([guildId, position])
  @@map("channel")
}

model Message {
  id        String    @id
  channelId String
  authorId  String
  content   String
  nonce     String
  createdAt DateTime  @default(now())
  updatedAt temporal.updatedAt()
  deletedAt DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@unique([authorId, nonce])
  @@index([channelId, createdAt, id])
  @@map("message")
}

model GuildInvite {
  id        String   @id
  guildId   String
  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?

  creator User  @relation("GuildInviteCreator", fields: [creatorId], references: [id])
  creatorId String

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@map("guild_invite")
}
