model User {
  id             String @id
  username       String
  homeserverName String
  displayName    String?
  avatarUrl      String?
  isBot          Boolean
  createdAt      DateTime
  updatedAt      DateTime

  sessions Session[]

  @@unique([username, homeserverName])
  @@map("user")
  LocalCredential LocalCredential[]
}

model LocalCredential {
  userId       String @id
  email        String @unique
  passwordHash String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("local_credential")
}

model Session {
  id         String   @id
  userId     String
  secretHash Bytes
  createdAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}
