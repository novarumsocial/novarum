model User {
  id             String @id
  username       String
  homeserverName String
  displayName    String?
  email          String? @unique
  passwordHash   String?
  avatarUrl      String?
  isBot          Boolean
  createdAt      DateTime
  updatedAt      DateTime

  sessions Session[]

  @@unique([username, homeserverName])
  @@map("user")
}

model Session {
  id         String   @id
  userId     String
  secretHash Bytes
  createdAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}